{
  "name": "openclaw-optimizer",
  "version": "1.0.2",
  "description": "OpenClaw optimizer toolkit including skill-stats analysis and suggestions",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "openclaw-optimizer": "dist/cli.js",
    "openclaw-skill-stats": "dist/cli.js"
  },
  "scripts": {
    "build": "./node_modules/typescript/bin/tsc -p .",
    "install:one-click": "bash ./scripts/install.sh",
    "install:dev": "bash ./scripts/install-dev.sh",
    "optimizer": "node dist/cli.js",
    "pack:release": "npm pack",
    "skill-stats": "node dist/cli.js",
    "test": "node --experimental-vm-modules node_modules/vitest/vitest.mjs run",
    "test:watch": "node --experimental-vm-modules node_modules/vitest/vitest.mjs"
  },
  "keywords": ["openclaw", "skill", "stats", "cli"],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "files": ["dist"]
}
