{
  "name": "openclaw-skill-stats",
  "version": "1.0.1",
  "description": "CLI to stats OpenClaw skill usage from session logs and suggest optimizations",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "openclaw-skill-stats": "dist/cli.js"
  },
  "scripts": {
    "build": "./node_modules/typescript/bin/tsc -p .",
    "skill-stats": "node dist/cli.js",
    "test": "node --experimental-vm-modules node_modules/vitest/vitest.mjs run",
    "test:watch": "node --experimental-vm-modules node_modules/vitest/vitest.mjs"
  },
  "keywords": ["openclaw", "skill", "stats", "cli"],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "files": ["dist"]
}
